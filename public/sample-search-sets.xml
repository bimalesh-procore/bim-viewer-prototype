<?xml version="1.0" encoding="UTF-8"?>
<!--
  Sample Navisworks-format Search Sets export.

  Use this file to exercise the "Import using .xml" flow in the
  Search Sets panel. Each <selectionset> defines one saved search;
  conditions evaluate against IFC element properties (IfcEntityType,
  Name, predefined type, etc.).

  Schema follows the Autodesk Navisworks "exchange" XML format so
  files round-trip with NW/Naviate exports.

  NOTE: Folder nesting is preserved — <selectionset> nodes without a
  <findspec> child are treated as folders; those with a <findspec>
  are leaf search sets. The import tree mirrors this structure exactly.
-->
<exchange xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" units="m" filename="sample-search-sets.xml">
  <selectionsets>

    <!-- ─── Architectural ──────────────────────────────────────────────── -->
    <selectionset name="Architectural" guid="aaaa0000-0000-0000-0000-000000000000">
      <selectionset name="All Walls" guid="11111111-1111-1111-1111-000000000001">
        <findspec mode="all" disjoint="0">
          <conditions>
            <condition test="equals" flags="0">
              <category>
                <name internal="LcOaSceneBaseUserName">Element</name>
              </category>
              <property>
                <name internal="LcOaSceneBaseClassUserName">Type</name>
              </property>
              <value>
                <data type="wstring">IfcWall</data>
              </value>
            </condition>
          </conditions>
          <locator>/</locator>
        </findspec>
      </selectionset>

      <selectionset name="All Doors" guid="11111111-1111-1111-1111-000000000002">
        <findspec mode="all" disjoint="0">
          <conditions>
            <condition test="equals" flags="0">
              <category>
                <name internal="LcOaSceneBaseUserName">Element</name>
              </category>
              <property>
                <name internal="LcOaSceneBaseClassUserName">Type</name>
              </property>
              <value>
                <data type="wstring">IfcDoor</data>
              </value>
            </condition>
          </conditions>
          <locator>/</locator>
        </findspec>
      </selectionset>

      <selectionset name="All Windows" guid="11111111-1111-1111-1111-000000000003">
        <findspec mode="all" disjoint="0">
          <conditions>
            <condition test="equals" flags="0">
              <category>
                <name internal="LcOaSceneBaseUserName">Element</name>
              </category>
              <property>
                <name internal="LcOaSceneBaseClassUserName">Type</name>
              </property>
              <value>
                <data type="wstring">IfcWindow</data>
              </value>
            </condition>
          </conditions>
          <locator>/</locator>
        </findspec>
      </selectionset>
    </selectionset>

    <!-- ─── Structural ─────────────────────────────────────────────────── -->
    <selectionset name="Structural" guid="bbbb0000-0000-0000-0000-000000000000">
      <selectionset name="Structural Beams" guid="22222222-2222-2222-2222-000000000001">
        <findspec mode="all" disjoint="0">
          <conditions>
            <condition test="equals" flags="0">
              <category>
                <name internal="LcOaSceneBaseUserName">Element</name>
              </category>
              <property>
