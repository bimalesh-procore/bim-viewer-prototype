        </findspec>
      </selectionset>
    </selectionset>

    <!-- ─── Level / Storey scoped ──────────────────────────────────────── -->
    <selectionset name="By Level" guid="dddd0000-0000-0000-0000-000000000000">
      <selectionset name="Level 1 — All Elements" guid="44444444-4444-4444-4444-000000000001">
        <findspec mode="all" disjoint="0">
          <conditions>
            <condition test="contains" flags="0">
              <category>
                <name internal="LcOaSceneBaseUserName">Element</name>
              </category>
              <property>
                <name internal="LcOaSceneBaseUserName">Name</name>
              </property>
              <value>
                <data type="wstring">Level 1</data>
              </value>
            </condition>
          </conditions>
          <locator>/</locator>
        </findspec>
      </selectionset>

      <selectionset name="Level 2 — All Elements" guid="44444444-4444-4444-4444-000000000002">
        <findspec mode="all" disjoint="0">
          <conditions>
            <condition test="contains" flags="0">
              <category>
                <name internal="LcOaSceneBaseUserName">Element</name>
              </category>
              <property>
                <name internal="LcOaSceneBaseUserName">Name</name>
              </property>
              <value>
                <data type="wstring">Level 2</data>
