    <!-- ─── Site / Civil ───────────────────────────────────────────────── -->
    <selectionset name="Site Elements" guid="55555555-5555-5555-5555-000000000001">
      <findspec mode="all" disjoint="0">
        <conditions>
          <condition test="equals" flags="0">
            <category>
              <name internal="LcOaSceneBaseUserName">Element</name>
            </category>
