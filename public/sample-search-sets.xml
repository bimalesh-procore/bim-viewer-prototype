              </property>
              <value>
                <data type="wstring">IfcBeam</data>
              </value>
            </condition>
          </conditions>
          <locator>/</locator>
        </findspec>
      </selectionset>

      <selectionset name="Structural Columns" guid="22222222-2222-2222-2222-000000000002">
        <findspec mode="all" disjoint="0">
          <conditions>
            <condition test="equals" flags="0">
              <category>
                <name internal="LcOaSceneBaseUserName">Element</name>
              </category>
              <property>
                <name internal="LcOaSceneBaseClassUserName">Type</name>
              </property>
              <value>
                <data type="wstring">IfcColumn</data>
              </value>
            </condition>
          </conditions>
          <locator>/</locator>
        </findspec>
      </selectionset>

      <selectionset name="Floor Slabs" guid="22222222-2222-2222-2222-000000000003">
        <findspec mode="all" disjoint="0">
          <conditions>
            <condition test="equals" flags="0">
              <category>
                <name internal="LcOaSceneBaseUserName">Element</name>
