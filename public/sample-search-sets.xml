              </property>
              <value>
                <data type="wstring">IfcSlab</data>
              </value>
            </condition>
          </conditions>
          <locator>/</locator>
        </findspec>
      </selectionset>
    </selectionset>

    <!-- ─── MEP ────────────────────────────────────────────────────────── -->
    <selectionset name="MEP" guid="cccc0000-0000-0000-0000-000000000000">
      <selectionset name="HVAC Ducts &amp; Pipes" guid="33333333-3333-3333-3333-000000000001">
        <findspec mode="any" disjoint="0">
          <conditions>
            <condition test="equals" flags="0">
              <category>
                <name internal="LcOaSceneBaseUserName">Element</name>
              </category>
              <property>
                <name internal="LcOaSceneBaseClassUserName">Type</name>
              </property>
              <value>
                <data type="wstring">IfcFlowSegment</data>
              </value>
            </condition>
            <condition test="equals" flags="0">
              <category>
                <name internal="LcOaSceneBaseUserName">Element</name>
              </category>
              <property>
                <name internal="LcOaSceneBaseClassUserName">Type</name>
              </property>
              <value>
                <data type="wstring">IfcFlowTerminal</data>
              </value>
            </condition>
          </conditions>
          <locator>/</locator>
        </findspec>
      </selectionset>

      <selectionset name="Plumbing Fixtures" guid="33333333-3333-3333-3333-000000000002">
        <findspec mode="all" disjoint="0">
          <conditions>
            <condition test="equals" flags="0">
